# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep secrets local)
.env
.env.local
.env.*
!.env.example

# local Python / Django environment
env/
**/env/
*.pyc
__pycache__/
*.sqlite3

# backend-specific
/backend/env/
/backend/db.sqlite3

# Django : fichiers statiques collectés (whitenoise)
staticfiles/
backend/staticfiles/

# Django : fichiers médias uploadés (si un jour images de recettes)
media/
backend/media/

# frontend-specific
/frontend/node_modules/
/frontend/.next/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# éditeurs
.vscode/
.idea/

# logs génériques
*.log